{
  "name": "securelore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @securelore/review-core && npm run build --workspace @securelore/memory && npm run build --workspace @securelore/agent-core && npm run build --workspace @securelore/slack-ui && npm run build --workspace @securelore/slack",
    "eve:info": "eve info",
    "eve:build": "eve build",
    "smoke:agent-offline": "npm run smoke:offline --workspace @securelore/agent-core",
    "smoke:openrouter": "npm run smoke:openrouter --workspace @securelore/agent-core",
    "smoke:review": "npm run smoke --workspace @securelore/review-core",
    "smoke:slack-artifacts": "npm run smoke:artifacts --workspace @securelore/slack",
    "smoke:slack-file": "npm run smoke:file --workspace @securelore/slack",
    "smoke:slack-form": "npm run smoke:form --workspace @securelore/slack",
    "smoke:slack-home": "npm run smoke:home --workspace @securelore/slack",
    "db:schema:apply": "npm run schema:apply --workspace @securelore/memory",
    "db:seed:policies": "npm run seed:policies --workspace @securelore/memory",
    "smoke:retrieve": "npm run smoke:retrieve --workspace @securelore/memory",
    "smoke:slack-policy": "npm run smoke:policy --workspace @securelore/slack"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.8",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/functions": "^3.7.5",
    "ai": "^7.0.16",
    "cohere-ai": "^8.0.0",
    "eve": "^0.20.0",
    "zod": "^4.4.3"
  }
}
