{
  "name": "securelore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @securelore/review-core && npm run build --workspace @securelore/memory && npm run build --workspace @securelore/slack-ui && npm run build --workspace @securelore/slack",
    "smoke:review": "npm run smoke --workspace @securelore/review-core",
    "smoke:slack-form": "npm run smoke:form --workspace @securelore/slack",
    "db:schema:apply": "npm run schema:apply --workspace @securelore/memory",
    "db:seed:policies": "npm run seed:policies --workspace @securelore/memory",
    "smoke:retrieve": "npm run smoke:retrieve --workspace @securelore/memory",
    "smoke:slack-policy": "npm run smoke:policy --workspace @securelore/slack"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "cohere-ai": "^8.0.0"
  }
}
