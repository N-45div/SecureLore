{
  "name": "securelore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @securelore/review-core && npm run build --workspace @securelore/slack-ui && npm run build --workspace @securelore/slack",
    "smoke:review": "npm run smoke --workspace @securelore/review-core",
    "smoke:slack-form": "npm run smoke:form --workspace @securelore/slack"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.4"
  }
}
