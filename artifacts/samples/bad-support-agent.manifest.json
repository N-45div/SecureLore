{
  "display_information": {
    "name": "Casey Support AI",
    "description": "AI support agent for every employee issue"
  },
  "features": {
    "bot_user": {
      "display_name": "Casey",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/help",
        "url": "http://localhost:3000/slack/commands",
        "description": "Ask for help",
        "usage_hint": "[anything]"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "groups:history",
        "im:history",
        "mpim:history",
        "files:read",
        "chat:write",
        "users:read.email",
        "admin.users.info"
      ],
      "user": [
        "chat:write",
        "groups:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "http://localhost:3000/slack/events",
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "file_shared"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "http://localhost:3000/slack/actions"
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  },
  "securelore_declared_features": [
    "Answer employee support questions",
    "Create support tickets",
    "Summarize recent channel context"
  ],
  "securelore_public_pages": {
    "landing_page_url": "",
    "privacy_policy_url": "",
    "support_page_url": ""
  },
  "securelore_ai_disclosure": {
    "model": "",
    "retention": "",
    "training_use": ""
  }
}
