{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://securelore.dev/schemas/review-packet.schema.json",
  "title": "SecureLoreReviewPacket",
  "type": "object",
  "required": [
    "packetVersion",
    "reviewId",
    "createdAt",
    "inputSummary",
    "overallRisk",
    "findings",
    "recommendedActions"
  ],
  "properties": {
    "packetVersion": {
      "type": "string",
      "const": "phase1"
    },
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "inputSummary": {
      "type": "object",
      "required": ["artifactTypes", "declaredFeatures"],
      "properties": {
        "artifactTypes": {
          "type": "array",
          "items": {
            "enum": [
              "slack_manifest",
              "oauth_scopes",
              "mcp_tools",
              "landing_page",
              "privacy_policy",
              "support_page",
              "marketplace_description",
              "repo",
              "demo_transcript"
            ]
          },
          "uniqueItems": true
        },
        "declaredFeatures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "overallRisk": {
      "type": "object",
      "required": ["grade", "summary"],
      "properties": {
        "grade": {
          "enum": ["low", "medium", "high", "reject"]
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "scopeJustifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scopeJustification"
      }
    },
    "mcpToolReviews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mcpToolReview"
      }
    },
    "recommendedActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendedAction"
      }
    },
    "policyContext": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyContext"
      }
    },
    "generatedArtifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/generatedArtifact"
      }
    },
    "lineage": {
      "type": "object",
      "required": ["parentReviewId"],
      "properties": {
        "parentReviewId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "comparison": {
      "type": "object",
      "required": ["beforeGrade", "afterGrade", "resolvedFindingIds", "remainingFindingIds", "newFindingIds"],
      "properties": {
        "beforeGrade": { "enum": ["low", "medium", "high", "reject"] },
        "afterGrade": { "enum": ["low", "medium", "high", "reject"] },
        "resolvedFindingIds": { "type": "array", "items": { "type": "string" } },
        "remainingFindingIds": { "type": "array", "items": { "type": "string" } },
        "newFindingIds": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["status", "rationale", "decidedBy", "decidedAt"],
      "properties": {
        "status": { "enum": ["approved", "changes_requested", "warnings_accepted"] },
        "rationale": { "type": "string" },
        "decidedBy": { "type": "string" },
        "decidedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "evalTrace": {
      "type": "object",
      "properties": {
        "fixtureIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "status"],
            "properties": {
              "name": {
                "type": "string"
              },
              "status": {
                "enum": ["pass", "fail", "not_run"]
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "category",
        "title",
        "description",
        "confidence",
        "fixability"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "enum": ["pass", "info", "warn", "blocker"]
        },
        "category": {
          "enum": [
            "oauth_scope_risk",
            "mcp_tool_safety",
            "marketplace_readiness",
            "ai_disclosure",
            "slack_privacy_model",
            "ux_admin_trust",
            "deployment_security"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policyCitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "enum": ["low", "medium", "high"]
        },
        "fixability": {
          "enum": ["manual", "automatic", "needs_clarification"]
        },
        "resolution": {
          "type": "object",
          "required": ["status", "rationale", "evaluatedBy", "evaluatedAt"],
          "properties": {
            "status": {
              "enum": ["evidence_submitted", "resolved", "accepted_risk"]
            },
            "rationale": { "type": "string" },
            "evaluatedBy": { "type": "string" },
            "evaluatedAt": { "type": "string", "format": "date-time" },
            "quality": {
              "type": "object",
              "required": ["relevance", "specificity", "testability", "policyAlignment"],
              "properties": {
                "relevance": { "type": "number", "minimum": 0, "maximum": 5 },
                "specificity": { "type": "number", "minimum": 0, "maximum": 5 },
                "testability": { "type": "number", "minimum": 0, "maximum": 5 },
                "policyAlignment": { "type": "number", "minimum": 0, "maximum": 5 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "scopeJustification": {
      "type": "object",
      "required": ["scope", "status", "declaredUse", "recommendation"],
      "properties": {
        "scope": {
          "type": "string"
        },
        "status": {
          "enum": ["justified", "overbroad", "missing_evidence", "remove"]
        },
        "declaredUse": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "mcpToolReview": {
      "type": "object",
      "required": ["toolName", "classification", "readOnlyHintStatus", "issues"],
      "properties": {
        "toolName": {
          "type": "string"
        },
        "classification": {
          "enum": ["read", "write", "ambiguous"]
        },
        "readOnlyHintStatus": {
          "enum": ["present_valid", "present_invalid", "missing", "not_applicable"]
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendedMetadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "policyContext": {
      "type": "object",
      "required": ["id", "title", "source", "excerpt"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "sourceUrl": {
          "type": "string"
        },
        "similarity": {
          "type": "number"
        },
        "excerpt": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "recommendedAction": {
      "type": "object",
      "required": ["id", "label", "priority", "description"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "priority": {
          "enum": ["now", "before_submission", "before_marketplace", "later"]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "generatedArtifact": {
      "type": "object",
      "required": ["type", "title", "content"],
      "properties": {
        "type": {
          "enum": [
            "manifest_diff",
            "fixed_manifest",
            "scope_justification_table",
            "marketplace_notes",
            "marketplace_checklist",
            "privacy_disclosure",
            "ai_disclosure",
            "admin_approval_brief",
            "manifest_patch_plan",
            "mcp_tool_metadata",
            "review_comparison"
          ]
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": ["string", "object", "array"]
        }
      },
      "additionalProperties": false
    }
  }
}
